{
  "name": "expert",
  "version": "2.0.0",
  "description": "Expert search — upload PDFs, extract their text, and run focused full-text academic searches.",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "node --watch server/index.js",
    "client:install": "npm --prefix client install",
    "client:dev": "npm --prefix client run dev",
    "build": "npm --prefix client install && npm --prefix client run build",
    "setup": "npm install && npm run build",
    "seed": "node server/scripts/seed.js",
    "verify": "bash ai/scripts/verify.sh"
  },
  "author": "Carlitos Willis",
  "license": "ISC",
  "dependencies": {
    "@extractus/article-extractor": "^8.1.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "multer": "^2.0.0",
    "mupdf": "^1.27.0",
    "mysql2": "^3.11.5",
    "pdf-parse": "^1.1.1",
    "tesseract.js": "^7.0.0"
  }
}
