# Copy to .env and adjust. All values are optional.
# With no DB_* set, the app uses a zero-config JSON store (data/sources.json).

# HTTP port for the Express server
PORT=3000

# --- MySQL (optional) -------------------------------------------------
# Set DB_HOST to switch from the JSON store to MySQL.
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=
# DB=my_db

# --- Paths (optional) -------------------------------------------------
# UPLOAD_DIR=./uploads
# DATA_DIR=./data
