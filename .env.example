# Copy to .env and adjust. All values are optional.
# With no DB_* set, the app uses a zero-config JSON store (data/sources.json).

# HTTP port for the Express server
PORT=3000

# --- MySQL (optional) -------------------------------------------------
# Set DB_HOST to switch from the JSON store to MySQL.
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=
# DB=my_db

# --- Paths (optional) -------------------------------------------------
# UPLOAD_DIR=./uploads
# DATA_DIR=./data

# --- OCR for scanned/image PDFs (optional) ----------------------------
# Pure-WASM (mupdf + tesseract.js); works with no config. Tunables:
# OCR_CONCURRENCY=4      # parallel pages/docs (default: min(cores-1, 6))
# OCR_DPI=200            # render resolution for OCR
# OCR_MIN_CHARS=40       # below this much text, treat a PDF as a scan -> OCR

# --- LLM metadata (optional) ------------------------------------------
# Auto-fill Title/Authors/Year from a source's text. Cascade: Gemini ->
# Gemma (Google's free API) -> local Ollama. With none set, nothing runs.
# GOOGLE_AI_API_KEY=         # free key from aistudio.google.com
# GEMINI_MODEL=gemini-2.5-flash
# GEMMA_MODEL=gemma-4-31b-it
# OLLAMA_API_BASE=http://127.0.0.1:11434
# OLLAMA_MODEL=qwen2.5-coder:14b
# When the year isn't in the text, look it up via Gemini's Google Search
# grounding (uses the free grounding quota). Disable with:
# METADATA_YEAR_SEARCH=0
